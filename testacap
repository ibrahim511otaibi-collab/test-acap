<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>نظام الجودة - مركز الفروانية</title>
    <style>
        :root { --primary: #2d5a27; --accent: #a00438; --bg: #f8f9fa; --locked: #e9ecef; }
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background-color: var(--bg); padding: 15px; margin: 0; }
        .card { max-width: 800px; margin: auto; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border-top: 8px solid var(--primary); }
        h2 { color: var(--primary); text-align: center; margin-bottom: 20px; border-bottom: 2px solid #eee; padding-bottom: 10px; }
        .section-title { background: #f0f4f0; padding: 10px; border-right: 5px solid var(--primary); margin: 25px 0 10px 0; font-weight: bold; }
        .form-group { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 8px; color: #444; }
        input, select, textarea { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px; box-sizing: border-box; }
        input:disabled, textarea:disabled, select:disabled { background-color: var(--locked); color: #666; cursor: not-allowed; }
        .btn-group { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 20px; }
        button { padding: 15px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 16px; transition: 0.3s; }
        .btn-save { background: var(--primary); color: white; width: 100%; margin-top: 10px; }
        .btn-whatsapp { background: #25D366; color: white; }
        .hidden { display: none; }
        .status-msg { background: #fff3cd; color: #856404; padding: 10px; border-radius: 8px; margin-bottom: 15px; text-align: center; font-weight: bold; }
        .radio-group { display: flex; flex-wrap: wrap; gap: 10px; background: #fff; padding: 10px; border: 1px solid #ddd; border-radius: 8px; }
        .radio-item { display: flex; align-items: center; gap: 5px; }
        .radio-item input { width: auto; }
    </style>
</head>
<body>

<div class="card">
    <h2>نظام إدارة عدم المطابقة (NCR)</h2>
    <div id="modeMessage" class="status-msg hidden">وضع المسؤول: يرجى تعبئة التحليل والإجراء التصحيحي فقط.</div>

    <div class="section-title">بيانات رصد الحالة (المدقق)</div>
    
    <div class="form-group">
        <label>رقم الحالة:</label>
        <input type="text" id="case_id" readonly style="background:#eee">
    </div>

    <div class="form-group">
        <label>اسم المدقق:</label>
        <input type="text" id="auditor_name" placeholder="أدخل اسمك">
    </div>

    <div class="form-group">
        <label>مصدر الحالة:</label>
        <div class="radio-group" id="source_group">
            <label class="radio-item"><input type="radio" name="source" value="شكوى"> شكوى</label>
            <label class="radio-item"><input type="radio" name="source" value="تدقيق داخلي"> تدقيق داخلي</label>
            <label class="radio-item"><input type="radio" name="source" value="ملاحظة"> ملاحظة</label>
            <label class="radio-item"><input type="radio" name="source" value="تحليل بيانات"> تحليل بيانات</label>
            <label class="radio-item"><input type="radio" name="source" value="مصدر آخر"> مصدر آخر</label>
        </div>
    </div>

    <div class="form-group">
        <label>مستوى الخطورة:</label>
        <select id="risk_level">
            <option value="منخفضة">منخفضة</option>
            <option value="متوسطة">متوسطة</option>
            <option value="عالية">عالية</option>
        </select>
    </div>

    <div class="form-group">
        <label>وصف حالة عدم المطابقة:</label>
        <textarea id="desc" rows="3" placeholder="اشرح الملاحظة بدقة..."></textarea>
    </div>

    <div id="managerSection">
        <div class="section-title">تحليل وإجراء المسؤول (CAPA)</div>
        <div class="form-group">
            <label>السبب الجذري (لماذا حصلت المشكلة؟):</label>
            <textarea id="root_cause" rows="3" placeholder="تحليل السبب الرئيسي..."></textarea>
        </div>
        <div class="form-group">
            <label>الإجراء التصحيحي (لحل المشكلة نهائياً):</label>
            <textarea id="action_plan" rows="3" placeholder="الخطوات المتخذة للتصحيح..."></textarea>
        </div>
        <div class="form-group">
            <label>اسم المسؤول المعتمد:</label>
            <input type="text" id="manager_name" placeholder="اسم رئيس القسم">
        </div>
    </div>

    <button class="btn-save" id="saveBtn" onclick="saveData()">حفظ البيانات في السجل</button>
    
    <div class="btn-group" id="auditorButtons">
        <button class="btn-whatsapp" onclick="notifyWhatsApp()">إرسال تنبيه للمسؤول (واتساب)</button>
    </div>
</div>

<script>
    const scriptURL = "https://script.google.com/macros/s/AKfycbwhDEfya6h-Tubr0evsvsLZIIW4Jq0RCjRkM4hW62XPqq4E_i6888oICoVyOAQC8wDq/exec";

    window.onload = function() {
        const urlParams = new URLSearchParams(window.location.search);
        const id = urlParams.get('id');
        
        if (id) {
            // وضع المسؤول
            document.getElementById('case_id').value = id;
            document.getElementById('desc').value = urlParams.get('desc');
            document.getElementById('risk_level').value = urlParams.get('risk');
            document.getElementById('auditor_name').value = urlParams.get('auditor');
            
            // قفل الخانات
            document.getElementById('desc').disabled = true;
            document.getElementById('risk_level').disabled = true;
            document.getElementById('auditor_name').disabled = true;
            document.querySelectorAll('input[name="source"]').forEach(el => el.disabled = true);
            
            document.getElementById('auditorButtons').classList.add('hidden');
            document.getElementById('modeMessage').classList.remove('hidden');
        } else {
            // وضع المدقق: توليد رقم حالة
            const dateStr = new Date().toLocaleDateString('en-GB').replace(/\//g, '');
            document.getElementById('case_id').value = "NCR-" + dateStr + "-" + Math.floor(Math.random() * 1000);
        }
    };

    function saveData() {
        const btn = document.getElementById('saveBtn');
        btn.disabled = true;
        btn.innerText = "جاري الحفظ...";

        const selectedSource = document.querySelector('input[name="source"]:checked')?.value || "";

        const data = {
            id: document.getElementById('case_id').value,
            auditor: document.getElementById('auditor_name').value,
            source: selectedSource,
            risk: document.getElementById('risk_level').value,
            desc: document.getElementById('desc').value,
            rootCause: document.getElementById('root_cause').value,
            action: document.getElementById('action_plan').value,
            manager: document.getElementById('manager_name').value
        };

        fetch(scriptURL, {
            method: 'POST',
            mode: 'no-cors',
            body: JSON.stringify(data)
        })
        .then(() => {
            alert("تمت العملية بنجاح!");
            btn.disabled = false;
            btn.innerText = "حفظ البيانات في السجل";
        })
        .catch(() => {
            alert("خطأ في الاتصال");
            btn.disabled = false;
        });
    }

    function notifyWhatsApp() {
        const id = document.getElementById('case_id').value;
        const desc = document.getElementById('desc').value;
        const risk = document.getElementById('risk_level').value;
        const auditor = document.getElementById('auditor_name').value;
        const phone = "96566695443";
        
        const baseUrl = window.location.href.split('?')[0];
        const smartUrl = `${baseUrl}?id=${id}&risk=${encodeURIComponent(risk)}&desc=${encodeURIComponent(desc)}&auditor=${encodeURIComponent(auditor)}`;
        
        const message = `*تنبيه حالة عدم مطابقة جيدة*%0A---%0A*رقم الحالة:* ${id}%0A*الخطورة:* ${risk}%0A*الوصف:* ${desc}%0A---%0A*يرجى الرد بالسبب والإجراء عبر الرابط:*%0A${smartUrl}`;
        
        window.open(`https://wa.me/${phone}?text=${message}`, '_blank');
    }
</script>

</body>
</html>
